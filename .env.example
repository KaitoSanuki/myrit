SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Internal job protection. Use as Authorization: Bearer <value> or ?secret=<value>.
CRON_SECRET=

# Discord webhook for daily summaries and job alerts.
DISCORD_WEBHOOK_URL=
DISCORD_STOP_SECRET=
REFERENCE_INGEST_SECRET=
REFERENCE_SCREENSHOT_MAX_BYTES=1500000

# Posting defaults.
DRY_RUN_POSTING=true
POST_TIMEZONE_OFFSET=+09:00
POSTS_PER_DAY=5
DAILY_POST_TIMES=08:00,12:00,16:00,19:00,22:00

# Local Codex CLI generation. Only used by npm run generate-posts:codex.
CODEX_BIN=codex
CODEX_MODEL=
CODEX_TIMEOUT_MS=180000
COMPETITOR_LOOKBACK_DAYS=3650

# X API. User OAuth token is required for posting.
X_USER_ACCESS_TOKEN=
X_BEARER_TOKEN=
COMPETITOR_COLLECT_DAYS=7
X_COMPETITOR_MAX_ACCOUNTS=10
X_COMPETITOR_TIMELINE_MAX_PAGES=3

# Threads API.
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=me
THREADS_API_BASE_URL=https://graph.threads.net

# Optional JSON array for competitor import.
# [{"competitor":"english_tip","platform":"x","content":"...","likes":12,"reposts":3,"replies":2,"posted_at":"2026-04-12T00:00:00.000Z"}]
COMPETITOR_POSTS_JSON=
